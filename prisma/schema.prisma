generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Director {  
  id          Int @id @default(autoincrement())
  name        String
  birthYear   Int
  movies    Movie[]
}

model Movie {
  id          Int @id @default(autoincrement())
  title       String
  releaseYear Int
  directorId  Int
  director    Director @relation(fields: [directorId], references: [id])
}
